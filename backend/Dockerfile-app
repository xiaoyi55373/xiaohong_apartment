# 小红公寓claw - APP模块 Dockerfile
FROM eclipse-temurin:17-jdk-alpine

LABEL maintainer="小红公寓claw"
LABEL app.name="xiaohong-apartment-app"
LABEL app.description="小红公寓claw移动端API服务"

WORKDIR /app

# 复制打包好的 jar 文件
COPY web/web-app/target/web-app-*.jar app.jar

# 暴露端口
EXPOSE 8082

# 启动命令（使用 prod 配置文件）
ENTRYPOINT ["java", "-jar", "-Dspring.profiles.active=prod", "app.jar"]
