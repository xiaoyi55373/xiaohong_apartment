<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xiaohong.lease.web.admin.mapper.ScheduledTaskMapper">

    <resultMap id="BaseResultMap" type="com.xiaohong.lease.model.entity.ScheduledTask">
        <id property="id" column="id"/>
        <result property="taskName" column="task_name"/>
        <result property="taskDescription" column="task_description"/>
        <result property="taskType" column="task_type"/>
        <result property="cronExpression" column="cron_expression"/>
        <result property="status" column="status"/>
        <result property="notifyEnabled" column="notify_enabled"/>
        <result property="notifyType" column="notify_type"/>
        <result property="remindDaysBefore" column="remind_days_before"/>
        <result property="taskParams" column="task_params"/>
        <result property="lastExecuteTime" column="last_execute_time"/>
        <result property="lastExecuteStatus" column="last_execute_status"/>
        <result property="lastExecuteResult" column="last_execute_result"/>
        <result property="executeCount" column="execute_count"/>
        <result property="successCount" column="success_count"/>
        <result property="failCount" column="fail_count"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="isDeleted" column="is_deleted"/>
    </resultMap>

    <!-- 查询所有启用的任务 -->
    <select id="selectEnabledTasks" resultMap="BaseResultMap">
        SELECT * FROM scheduled_task 
        WHERE status = 1 AND is_deleted = 0
        ORDER BY id ASC
    </select>

    <!-- 根据任务类型查询任务 -->
    <select id="selectByTaskType" resultMap="BaseResultMap">
        SELECT * FROM scheduled_task 
        WHERE task_type = #{taskType} AND is_deleted = 0
        LIMIT 1
    </select>

</mapper>
