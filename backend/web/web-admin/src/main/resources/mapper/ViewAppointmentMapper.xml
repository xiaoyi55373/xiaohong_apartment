<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xiaohong.lease.web.admin.mapper.ViewAppointmentMapper">

    <resultMap id="appointmentVoMap" type="com.xiaohong.lease.web.admin.vo.appointment.AppointmentVo" autoMapping="true">
        <id property="id" column="id"/>
        <association property="apartmentInfo" javaType="com.xiaohong.lease.model.entity.ApartmentInfo" autoMapping="true">
            <id property="id" column="apartment_id"/>
            <result property="name" column="apartment_name"/>
            <result property="phone" column="apartment_phone"/>
        </association>
    </resultMap>

    <resultMap id="BaseResultMap" type="com.xiaohong.lease.model.entity.ViewAppointment">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="name" column="name"/>
        <result property="phone" column="phone"/>
        <result property="apartmentId" column="apartment_id"/>
        <result property="appointmentTime" column="appointment_time"/>
        <result property="additionalInfo" column="additional_info"/>
        <result property="appointmentStatus" column="appointment_status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="isDeleted" column="is_deleted"/>
    </resultMap>

    <select id="pageItem" resultMap="appointmentVoMap">
        select va.id,
               va.user_id,
               va.name,
               va.phone,
               va.appointment_time,
               va.additional_info,
               va.appointment_status,
               ai.id    apartment_id,
               ai.name  apartment_name,
               ai.introduction,
               ai.district_id,
               ai.district_name,
               ai.city_id,
               ai.city_name,
               ai.province_id,
               ai.province_name,
               ai.address_detail,
               ai.latitude,
               ai.longitude,
               ai.phone apartment_phone,
               ai.is_release
        from view_appointment va
                 left join
             apartment_info ai
             on va.apartment_id = ai.id
            <where>
                va.is_deleted = 0
                <if test="queryVo.provinceId != null">
                    and ai.province_id = #{queryVo.provinceId}
                </if>
                <if test="queryVo.cityId != null">
                    and ai.city_id = {#queryVo.cityId}
                </if>
                <if test="queryVo.districtId != null">
                    and ai.district_id = #{queryVo.districtId}
                </if>
                <if test="queryVo.apartmentId != null">
                    and va.apartment_id = #{queryVo.apartmentId}
                </if>
                <if test="queryVo.name != null and queryVo.name != ''">
                    and va.name like '%${queryVo.name}%'
                </if>
                <if test="queryVo.phone != null and queryVo.phone != ''">
                    and va.phone like '%${queryVo.phone}%'
                </if>
            </where>
    </select>

    <!-- 查询已过期的预约 -->
    <select id="selectExpiredAppointments" resultMap="BaseResultMap">
        SELECT * FROM view_appointment
        WHERE is_deleted = 0
          AND appointment_status = #{status.code}
          AND appointment_time &lt; #{expireTime}
        ORDER BY appointment_time ASC
    </select>

</mapper>
