# 小红公寓claw - 后台管理模块 Dockerfile
FROM eclipse-temurin:17-jdk-alpine

LABEL maintainer="小红公寓claw"
LABEL app.name="xiaohong-apartment-admin"
LABEL app.description="小红公寓claw后台管理系统"

WORKDIR /app

# 复制打包好的 jar 文件
COPY web/web-admin/target/web-admin-*.jar app.jar

# 暴露端口
EXPOSE 8080

# 启动命令（使用 prod 配置文件）
ENTRYPOINT ["java", "-jar", "-Dspring.profiles.active=prod", "app.jar"]
